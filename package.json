{
  "name": "@elastic/monaco-esql",
  "version": "3.3.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "Monaco editor Monarch language syntax definitions for ES|QL",
  "main": "lib/index.js",
  "files": [
    "NOTICE.txt",
    "LICENSE",
    "lib/"
  ],
  "scripts": {
    "format": "biome format ./src",
    "format:fix": "biome format --write ./src",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "echo \"no tests...\"",
    "clean": "npx rimraf@5.0.5 lib",
    "build:es2020": "tsc --project tsconfig.build.json",
    "build": "yarn build:es2020",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "semantic-release:dry-run": "semantic-release --dry-run --debug",
    "prepare": "husky"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elastic/monaco-esql.git"
  },
  "keywords": [
    "esql",
    "es|ql",
    "elastic",
    "search processing language",
    "eql",
    "monacor",
    "monarch",
    "vscode",
    "code",
    "syntax"
  ],
  "bugs": {
    "url": "https://github.com/elastic/monaco-esql/issues"
  },
  "homepage": "https://github.com/elastic/monaco-esql",
  "peerDependencies": {
    "monaco-editor": "*",
    "monaco-promql": "*"
  },
  "peerDependenciesMeta": {
    "monaco-promql": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/eslint-parser": "7.28.6",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@biomejs/biome": "2.4.10",
    "@chromatic-com/storybook": "5.1.1",
    "@eslint/js": "10.0.1",
    "@monaco-editor/react": "4.7.0",
    "@storybook/addon-docs": "10.3.4",
    "@storybook/addon-onboarding": "10.3.4",
    "@storybook/addon-vitest": "10.3.4",
    "@storybook/react-vite": "10.3.4",
    "@types/react": "19.2.14",
    "@vitest/browser": "4.1.2",
    "@vitest/browser-playwright": "4.1.2",
    "@vitest/coverage-v8": "4.1.2",
    "eslint": "10.2.0",
    "eslint-plugin-react": "7.37.5",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "monaco-editor": "0.55.1",
    "monaco-promql": "1.8.0",
    "playwright": "1.59.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "semantic-release": "25.0.3",
    "storybook": "10.3.4",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.2",
    "vitest": "4.1.2"
  },
  "lint-staged": {
    "*.{js,ts,tsx,mjs}": [
      "eslint --fix"
    ]
  }
}
